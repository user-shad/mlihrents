# Copy to Vercel → Environment Variables on a NEW project (not mlihrents production).
# Use a new sync token and new Redis/Blob storage so demo data stays isolated.

VITE_SITE_PROFILE=sample
VITE_SITE_BRAND=Sample Rents
VITE_SITE_HERO_TITLE=Sample
VITE_SITE_HERO_ACCENT=Rents
VITE_PUBLIC_SITE_URL=https://YOUR-PROJECT.vercel.app
PUBLIC_SITE_URL=https://YOUR-PROJECT.vercel.app
VITE_PRIMARY_DOMAIN=YOUR-PROJECT.vercel.app

# Generate a fresh random string — must NOT match production mlihrents.
SYNC_API_TOKEN=replace-with-new-random-token
VITE_SYNC_API_TOKEN=replace-with-new-random-token

# Optional — separate WhatsApp branding for demo
WHATSAPP_BRAND_NAME=Sample Rents

# Storage — connect NEW Redis or Blob on this Vercel project (see SETUP-SYNC.md).
# Do not reuse production mlihrents storage credentials.
