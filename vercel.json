{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 15
    }
  },
  "redirects": [
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "mlihrents.com" }],
      "destination": "https://mlihrents.vercel.app/:path*",
      "permanent": false
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "www.mlihrents.com" }],
      "destination": "https://mlihrents.vercel.app/:path*",
      "permanent": false
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "mlaihrent.com" }],
      "destination": "https://mlihrents.vercel.app/:path*",
      "permanent": false
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "www.mlaihrent.com" }],
      "destination": "https://mlihrents.vercel.app/:path*",
      "permanent": false
    }
  ],
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
