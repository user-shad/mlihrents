{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mlihrents.vercel.app" }],
      "destination": "https://mlihrents.ae/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.mlihrents.ae" }],
      "destination": "https://mlihrents.ae/:path*",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
