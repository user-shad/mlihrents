{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/whatsapp-reminders",
      "schedule": "0 5 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mlihrent.com" }],
      "destination": "https://www.mlihrent.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "mlihrents.vercel.app" }],
      "destination": "https://www.mlihrent.com/:path*",
      "permanent": false
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "mlihrents.com" }],
      "destination": "https://www.mlihrent.com/:path*",
      "permanent": false
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "www.mlihrents.com" }],
      "destination": "https://www.mlihrent.com/:path*",
      "permanent": false
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "mlaihrent.com" }],
      "destination": "https://www.mlihrent.com/:path*",
      "permanent": false
    },
    {
      "source": "/:path((?!api/).*)",
      "has": [{ "type": "host", "value": "www.mlaihrent.com" }],
      "destination": "https://www.mlihrent.com/:path*",
      "permanent": false
    }
  ],
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
